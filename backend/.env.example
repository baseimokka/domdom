# Copy to .env and fill in real values. Never commit the real .env.

# Server port
PORT=3000

# REQUIRED. Long random secret used to sign JWTs (min 32 chars).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# REQUIRED. MySQL connection string for Prisma.
DATABASE_URL="mysql://user:password@localhost:3306/domdom"

# Comma-separated list of allowed CORS origins in production
# (e.g. https://domdom.com,https://www.domdom.com). Leave empty for local dev.
CORS_ORIGIN=

# Set to 1 (or the proxy hop count) when running behind nginx / a load balancer.
TRUST_PROXY=
